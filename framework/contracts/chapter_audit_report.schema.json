{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chapter_audit_report.schema.json",
  "title": "Chapter Audit Report",
  "type": "object",
  "required": [
    "schema_version",
    "book_id",
    "chapter_id",
    "audit_result",
    "blocking_issues",
    "non_blocking_issues",
    "coverage_check",
    "faithfulness_check",
    "continuity_check",
    "final_decision"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "book_id": { "type": "string" },
    "chapter_id": { "type": "string" },
    "audit_result": {
      "type": "string",
      "enum": ["pass", "fail", "needs_revision"]
    },
    "blocking_issues": { "type": "array" },
    "non_blocking_issues": { "type": "array" },
    "coverage_check": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "faithfulness_check": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "continuity_check": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "final_decision": {
      "type": "string",
      "enum": ["allow_freeze", "block_freeze", "revise_and_retry"]
    }
  },
  "additionalProperties": false
}
